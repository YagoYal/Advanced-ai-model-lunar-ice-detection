# Ambiente de execução — "production" ativa HTTPS redirect, HSTS e API key auth
ENV=production

# API Key obrigatória em produção (deve coincidir com VITE_API_KEY no frontend)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Origins permitidos no CORS (separados por vírgula, sem espaço)
ALLOWED_ORIGINS=https://seu-frontend.vercel.app

# Fonte de dados: "real" usa data/processed/lro/, "mock" usa data/processed/lro/mock/
DATA_MODE=real
