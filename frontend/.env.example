# Copie para .env.production e preencha antes de rodar: npm run build

# URL pública do backend FastAPI — OBRIGATÓRIA em produção (deve usar HTTPS)
# Sem esta variável o frontend lança erro ao carregar.
VITE_API_URL=https://seu-backend.railway.app

# API Key do backend — deve coincidir com API_KEY definida no servidor
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
VITE_API_KEY=
